# Database
# Runtime connection (CRUD only). Required.
DATABASE_URL=postgresql://daubert:daubert@localhost:5433/daubert

# Admin connection (owner role) — only used by ./migrations.sh in production.
# In dev, leave blank or unset; migrations.sh --dev uses DATABASE_URL.
# DATABASE_ADMIN_URL=postgresql://owner:password@host/db?sslmode=require

# Blockchain API keys
ETHERSCAN_API_KEY=your-etherscan-api-key
TRONSCAN_API_KEY=your-tronscan-api-key

# Anthropic API key
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Firebase (required for auth)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Data Room (Google Drive integration). Hard-required in production.
# 32-byte AES-256-GCM key for encrypting OAuth tokens at rest. Generate with `openssl rand -hex 32`.
DATAROOM_ENCRYPTION_KEY=replace-with-64-hex-chars-from-openssl-rand-hex-32
# Google OAuth client credentials (Google Cloud Console → APIs & Services → Credentials).
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
# Must exactly match the redirect URI configured for the OAuth client.
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8081/data-room/oauth-callback
# Frontend origin — OAuth callback redirects users back here after success.
FRONTEND_URL=http://localhost:3001
