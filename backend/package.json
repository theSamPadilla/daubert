    "firebase-admin": "^13.8.0",
    "googleapis": "^171.4.0",
    "isolated-vm": "^6.1.2",
    "isomorphic-dompurify": "^3.10.0",
    "pg": "^8.13.0",
    "puppeteer-core": "^24.42.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/testing": "^11.1.19",
    "@types/busboy": "^1.5.4",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
