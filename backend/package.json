    "start:prod": "NODE_OPTIONS=--no-node-snapshot node dist/main",
    "gen": "node scripts/gen-api.mjs",
    "scripts:migrate-to-auth": "ts-node scripts/migrate-to-auth.ts",
    "scripts:create-user": "ts-node scripts/create-user.ts",
    "scripts:create-case": "ts-node scripts/create-case.ts",
    "scripts:add-to-case": "ts-node scripts/add-to-case.ts",
    "scripts:list-users": "ts-node scripts/list-users.ts",
    "scripts:remove-member": "ts-node scripts/remove-member.ts",
    "scripts:change-role": "ts-node scripts/change-role.ts",
    "test": "NODE_OPTIONS=--no-node-snapshot jest",
    "test:watch": "NODE_OPTIONS=--no-node-snapshot jest --watch",
    "test:cov": "NODE_OPTIONS=--no-node-snapshot jest --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
