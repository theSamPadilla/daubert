# Backend API
NEXT_PUBLIC_API_URL=http://localhost:8081

# Browser API key used by the Google Drive Picker SDK on the data room page.
# Browser-exposed; restrict in Cloud Console to your domain + Picker API +
# Drive API. Distinct from GOOGLE_OAUTH_CLIENT_ID (which is server-side).
NEXT_PUBLIC_DRIVE_PICKER_KEY=your-drive-picker-key

# Firebase (required for auth)
# NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
# NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
